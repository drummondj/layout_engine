Terminals which are not used

   K_HISTORY
   K_ABUT
   K_COLUMNMAJOR
   K_FIXED
   K_MATCH
   K_NETS
   K_NEW
   K_ORIENTATION
   K_OVERLAPS
   K_PLACED
   K_ROWMAJOR
   K_SPECIALNETS
   K_ENDMACRO
   K_ENDMACROPIN
   K_ENDVIARULE
   K_ENDVIA
   K_ENDLAYER
   K_ENDSITE
   K_DEFINE
   K_DEFINES
   K_DEFINEB
   K_ENDEXT
   K_OPENFILE
   K_CLOSEFILE
   K_WARNING
   K_ERROR
   K_FATALERROR
   K_ROWMINSPACING
   K_ROWABUTSPACING
   K_FLIP
   K_ORIENT


Grammar

    0 $accept: lef_file $end

    1 lef_file: rules extension_opt end_library

    2 @1: /* empty */

    3 version: K_VERSION @1 T_STRING ';'

    4 int_number: NUMBER

    5 dividerchar: K_DIVIDERCHAR QSTRING ';'

    6 busbitchars: K_BUSBITCHARS QSTRING ';'

    7 rules: /* empty */
    8      | rules rule
    9      | error

   10 end_library: /* empty */
   11            | K_END K_LIBRARY

   12 rule: version
   13     | busbitchars
   14     | case_sensitivity
   15     | units_section
   16     | layer_rule
   17     | via
   18     | viarule
   19     | viarule_generate
   20     | dividerchar
   21     | wireextension
   22     | msg_statement
   23     | spacing_rule
   24     | dielectric
   25     | minfeature
   26     | irdrop
   27     | site
   28     | macro
   29     | array
   30     | nondefault_rule
   31     | prop_def_section
   32     | universalnoisemargin
   33     | edgeratethreshold1
   34     | edgeratescalefactor
   35     | edgeratethreshold2
   36     | noisetable
   37     | correctiontable
   38     | input_antenna
   39     | output_antenna
   40     | inout_antenna
   41     | antenna_input
   42     | antenna_inout
   43     | antenna_output
   44     | manufacturing
   45     | fixedmask
   46     | useminspacing
   47     | clearancemeasure
   48     | maxstack_via
   49     | create_file_statement

   50 case_sensitivity: K_NAMESCASESENSITIVE K_ON ';'
   51                 | K_NAMESCASESENSITIVE K_OFF ';'

   52 wireextension: K_NOWIREEXTENSIONATPIN K_ON ';'
   53              | K_NOWIREEXTENSIONATPIN K_OFF ';'

   54 fixedmask: K_FIXEDMASK ';'

   55 manufacturing: K_MANUFACTURINGGRID int_number ';'

   56 useminspacing: K_USEMINSPACING spacing_type spacing_value ';'

   57 clearancemeasure: K_CLEARANCEMEASURE clearance_type ';'

   58 clearance_type: K_MAXXY
   59               | K_EUCLIDEAN

   60 spacing_type: K_OBS
   61             | K_PIN

   62 spacing_value: K_ON
   63              | K_OFF

   64 units_section: start_units units_rules K_END K_UNITS

   65 start_units: K_UNITS

   66 units_rules: /* empty */
   67            | units_rules units_rule

   68 units_rule: K_TIME K_NANOSECONDS int_number ';'
   69           | K_CAPACITANCE K_PICOFARADS int_number ';'
   70           | K_RESISTANCE K_OHMS int_number ';'
   71           | K_POWER K_MILLIWATTS int_number ';'
   72           | K_CURRENT K_MILLIAMPS int_number ';'
   73           | K_VOLTAGE K_VOLTS int_number ';'
   74           | K_DATABASE K_MICRONS int_number ';'
   75           | K_FREQUENCY K_MEGAHERTZ NUMBER ';'

   76 layer_rule: start_layer layer_options end_layer

   77 @2: /* empty */

   78 start_layer: K_LAYER @2 T_STRING

   79 @3: /* empty */

   80 end_layer: K_END @3 T_STRING

   81 layer_options: /* empty */
   82              | layer_options layer_option

   83 layer_option: K_MANUFACTURINGGRID int_number ';'

   84 @4: /* empty */

   85 @5: /* empty */

